# ContractHubs API — environment template (AWS me-central-1, Multi-AZ).
# Copy to `.env` for local dev. NEVER commit real secrets.

NODE_ENV=development
PORT=3000

# Aurora PostgreSQL — append-only double-entry ledger lives here (single store).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/contracthubs

# ElastiCache Redis — sessions, idempotency fast-path, slot-booking locks, rate limits.
REDIS_URL=redis://localhost:6379

# Stripe (PSP only — wallet/ledger/settlement are in-house).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# UAE Pass (OIDC -> Emirates ID).
UAE_PASS_ISSUER=
UAE_PASS_CLIENT_ID=
UAE_PASS_CLIENT_SECRET=
UAE_PASS_REDIRECT_URI=

# Mobile OTP (TDRA-compliant, transactional SMS only).
SMS_PROVIDER_API_KEY=

# Passport IDV / OCR vendor (KYC).
KYC_OCR_API_KEY=

# AWS
AWS_REGION=me-central-1
S3_DOCUMENTS_BUCKET=
KMS_DOCUMENTS_KEY_ID=
EVENTBRIDGE_BUS_NAME=
SQS_OUTBOX_QUEUE_URL=
SQS_OUTBOX_DLQ_URL=

# Zoho CRM (one-way downstream sync — Contract Hubs is the System of Record).
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Auth (custom in-house identity — jose / argon2).
JWT_SIGNING_KEY=
