{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@contracthubs/config/tsconfig/nest.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "baseUrl": ".",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["node", "jest"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
